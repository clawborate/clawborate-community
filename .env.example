# ============================================================
# Clawborate Community Edition — Environment Configuration
# Copy to .env and fill in your values before running:
#   cp .env.example .env
# ============================================================

# --- Version ---
VERSION=latest

# --- Docker images ---
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.4.15

# --- Ports ---
FRONTEND_PORT=3000
BACKEND_PORT=8001

# --- Database ---
# Password for the dedicated 'clawborate' PostgreSQL user.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(16))"
APP_DB_PASSWORD=CHANGE_ME

# --- JWT auth ---
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME

# --- OpenClaw gateway auth ---
# Shared secret between backend and each agent container.
OPENCLAW_GATEWAY_TOKEN=changeme_gateway

# --- LLM provider config ---
# Provider: anthropic | openai | ollama | custom
LLM_PROVIDER=custom

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# OPENAI_API_KEY=sk-...

# Ollama (local, no API key needed)
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# Custom OpenAI-compatible endpoint (MLX, LiteLLM, vLLM, etc.)
LLM_BASE_URL=http://host.docker.internal:8000/v1
LLM_API_KEY=
LLM_MODEL=your_model_name_here
LLM_CONTEXT_WINDOW=32768
LLM_MAX_TOKENS=4096

# --- Default user (seeded on first run) ---
DEFAULT_USER_EMAIL=test@test.com
DEFAULT_USER_PASSWORD=test
DEFAULT_USER_NAME=Admin

# --- Open WebUI ---
OPENWEBUI_API_KEY=
OPENWEBUI_ADMIN_EMAIL=admin@clawborate.local
OPENWEBUI_ADMIN_PASSWORD=clawborate-admin-2024
OPENWEBUI_DB_PASSWORD=openwebui
WEBUI_FRAME_ANCESTORS=http://localhost:3000

# --- Agent settings ---
# Map agent port 18789 to random host ports for direct browser access.
EXPOSE_AGENT_PORTS=false

# Reuse the user's Open WebUI chat session for notification replies.
DISPATCHER_USE_USER_SESSION=true
